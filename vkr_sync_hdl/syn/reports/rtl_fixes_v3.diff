+wire signed [W_MUL2-1:0] v0_aligned_i = {{(W_MUS + W_MU){v0_s2_d_i[W_V-1]}}, v0_s2_d_i} <<< (2*W_MU);
+wire signed [W_MUL2-1:0] v0_aligned_q = {{(W_MUS + W_MU){v0_s2_d_q[W_V-1]}}, v0_s2_d_q} <<< (2*W_MU);
 
